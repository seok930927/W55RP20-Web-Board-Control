[ req ]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
req_extensions = v3_req

[ dn ]
C = KR
ST = Seoul
L = Seoul
O = WIZnet Local Dev
OU = HTTPS Test
CN = 192.168.11.118

[ v3_req ]
subjectAltName = @alt_names
basicConstraints = CA:false
keyUsage = critical, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth

[ alt_names ]
IP.1 = 192.168.11.118
DNS.1 = 192.168.11.118
